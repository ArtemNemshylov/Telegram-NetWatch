# ─────────────────────────────────────────────
#  Telegram NetWatch — configuration
#  Copy this file to .env and fill in the values
#    cp .env.example .env   (or: make setup)
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────

# Telegram bot token (get from @BotFather → /newbot)
TELEGRAM_TOKEN=

# Chat ID to receive alerts (get from @userinfobot → /start)
TELEGRAM_CHAT_ID=

# ── DNS proxy ─────────────────────────────────

# Upstream DNS server to forward queries to (default: Google)
# UPSTREAM_DNS=8.8.8.8

# Port to forward upstream queries to (default: 53)
# UPSTREAM_PORT=53

# Address and port to listen on (default: all interfaces, port 53)
# LISTEN_HOST=0.0.0.0
# LISTEN_PORT=53

# ── MitM mode (mitm.py only) ──────────────────

# Gateway IP (default: auto-detect from routing table)
# GATEWAY_IP=192.168.1.1

# Specific IPs to monitor — comma-separated (default: all devices on the network)
# TARGET_IPS=192.168.1.42,192.168.1.55

# Network range to scan for hosts (default: auto-detect /24 from gateway)
# NETWORK=192.168.1.0/24

# Seconds between ARP packets — lower = more reliable, higher = less noise (default: 2)
# SPOOF_INTERVAL=2

# ── Watchlist ─────────────────────────────────

# Watchlist URL — any plain-text list with one domain per line
# BLOCKLIST_URL=https://raw.githubusercontent.com/chadmayfield/my-pihole-blocklists/master/lists/pi_blocklist_porn_all.list

# How often to re-download the watchlist (hours, default: 24)
# REFRESH_HOURS=24

# ── Behaviour ─────────────────────────────────

# Minimum seconds between repeated notifications for the same device+domain (default: 300)
# COOLDOWN_SEC=300

# Print every DNS query to stdout, not just tracked ones (default: false)
# DEBUG=false
